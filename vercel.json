{
  "crons": [
    {
      "path": "/api/push/process",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/publish-group-feed-carousel",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/publish-group-recurring",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/onboarding-messages",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/weekly-group-trivia",
      "schedule": "0 16,17 * * 2"
    },
    {
      "path": "/api/cron/update-monday",
      "schedule": "0 16,17 * * 1"
    },
    {
      "path": "/api/cron/weekly-group-poll",
      "schedule": "0 16,17 * * 3"
    },
    {
      "path": "/api/cron/weekly-group-question",
      "schedule": "0 16,17 * * 4"
    },
    {
      "path": "/api/cron/who-was-this-friday",
      "schedule": "0 16,17 * * 5"
    },
    {
      "path": "/api/cron/bible-study-saturday",
      "schedule": "0 16,17 * * 6"
    },
    {
      "path": "/api/cron/prayer-request-sunday",
      "schedule": "0 16,17 * * 0"
    },
    {
      "path": "/api/cron/weekly-bible-report",
      "schedule": "0 18 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
